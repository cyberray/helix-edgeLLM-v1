# Copy this file to .env and fill in your real keys.
# Never commit .env to source control.

# Optional cloud API keys for hybrid routing
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Optional override (default is free model)
OPENROUTER_MODEL=inclusionai/ring-2.6-1t:free
# Optional: force cloud routing to free models where possible
FREE_LLM_ONLY=true
# Optional: additional free OpenRouter models to try on cloud errors (comma-separated)
OPENROUTER_FREE_FALLBACK_MODELS=meta-llama/llama-3.1-8b-instruct:free,google/gemma-3-4b-it:free
# Optional: retries for 429 rate limits (per model)
OPENROUTER_MAX_RETRIES=2
# Optional: base seconds for exponential backoff (0.75 -> 0.75s, 1.5s, 3.0s)
OPENROUTER_RETRY_BASE_SECONDS=0.75
# Optional fallback behavior on OpenRouter error: local|error
OPENROUTER_FALLBACK_MODE=local
TOGETHER_API_KEY=your_together_api_key_here
HF_API_TOKEN=your_huggingface_api_token_here
# Optional compatibility alias (some tools may read this name instead)
HF_API_KEY=your_huggingface_api_key_here
